# Copy this file to .env and fill in values. Never commit .env.

# Razorpay — enable real online checkout (Test mode keys for development)
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Online pay without Razorpay (college / test): ON by default when DEBUG=True and Razorpay keys are empty.
# Set to false only if you want to hide it and show Razorpay setup instructions only:
# FAKE_ONLINE_PAYMENT=false

# Live chat (Tawk.to, free): https://www.tawk.to → create property → Admin → Channels → widget
# Paste the two hex IDs from your embed URL: https://embed.tawk.to/PROPERTY_ID/WIDGET_ID
# TAWK_TO_PROPERTY_ID=
# TAWK_TO_WIDGET_ID=
